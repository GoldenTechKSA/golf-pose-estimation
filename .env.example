# Copy to .env and fill in. docker-compose reads this file automatically.

# --- AI coaching (optional — analysis works without it, coaching is skipped) ---
ANTHROPIC_API_KEY=
COACHING_MODEL=claude-sonnet-5

# --- Pose model ---
# Any ultralytics *-pose checkpoint. Falls back to yolo11m-pose.pt if the
# primary can't be loaded.
#
# Docker on Apple Silicon / any CPU-only host runs inference on CPU (no GPU
# passthrough), so this defaults to the fast nano model. Rough per-frame CPU
# cost at POSE_IMGSZ=640: yolo11n ~70ms, yolo11s ~165ms, yolo26m ~480ms.
# On a GPU box, switch to yolo26m-pose.pt for best accuracy.
POSE_MODEL=yolo11n-pose.pt
# Inference resolution (long side). 640 = model default; 512 is ~1.7x faster
# on CPU with a small accuracy cost.
POSE_IMGSZ=640

# --- Infrastructure ---
POSTGRES_PASSWORD=swinglens
# URL the browser uses to reach the API (baked into the web build).
NEXT_PUBLIC_API_URL=http://localhost:8000
